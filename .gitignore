# Data files (large, user-specific)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Output (regeneratable)
output/figures/*
output/tables/*
!output/figures/.gitkeep
!output/tables/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
*.egg-info/
venv/
.venv/

# R
.Rhistory
.RData

# LaTeX
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.synctex.gz

# IDE
.vscode/
.idea/

# Environment
.env
*.env.local
